{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://YOUR-PANEL-IP:YOUR-PANEL-PORT/api/:path*"
    },
    {
      "source": "/e/:path*",
      "destination": "http://YOUR-PANEL-IP:YOUR-PANEL-PORT/e/:path*"
    },
    {
      "source": "/cdn/:path*",
      "destination": "http://YOUR-PANEL-IP:YOUR-PANEL-PORT/cdn/:path*"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/index.html"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    }
  ]
}
