# ─────────────────────────────────────────────
# embedg-app  –  LOCAL DEVELOPMENT (.env)
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Leave empty in local dev — Vite will proxy /api → localhost:8080 automatically.
# In production (Vercel / Netlify) set this to your Railway / Render backend URL.
VITE_API_BASE_URL=

# Only needed for Discord Activity mode. Leave false for normal hosting.
VITE_DISCORD_ACTIVITY=false
